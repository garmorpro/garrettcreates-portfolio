---
---

<section class="relative px-6 pt-32 pb-24 sm:pt-40 sm:pb-32 lg:px-12">
  <div class="mx-auto flex max-w-6xl flex-col items-center text-center">
    <!-- Availability badge -->
    <div
      class="mb-8 inline-flex items-center gap-2 rounded-full border border-stone bg-offwhite px-4 py-2 text-sm font-medium text-charcoal"
    >
      <span class="h-2 w-2 rounded-full bg-clay"></span>
      Currently booking July 2026
    </div>

    <!-- Headline -->
    <h1
      class="max-w-4xl font-[family-name:var(--font-display)] text-5xl leading-[1.1] font-medium text-ink sm:text-6xl lg:text-7xl"
    >
      Tech that feels human.
      <span class="text-clay">Homes that feel real.</span>
    </h1>

    <!-- Supporting paragraph -->
    <p class="mt-8 max-w-2xl text-lg leading-relaxed text-charcoal/80 sm:text-xl">
      I'm Garrett — a UGC creator who helps tech, app, and home brands turn
      everyday products into content people actually want to watch.
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col gap-4 sm:flex-row">
      <a
        href="#contact"
        class="rounded-full bg-ink px-8 py-4 text-base font-semibold text-cream shadow-sm transition hover:scale-[1.02] hover:shadow-md"
      >
        Work With Me
      </a>
      <a
        href="#videos"
        class="rounded-full border border-charcoal/15 bg-transparent px-8 py-4 text-base font-semibold text-charcoal transition hover:border-charcoal/30 hover:bg-offwhite"
      >
        Watch My Reel
      </a>
    </div>

    <!-- Social proof placeholder -->
    <p class="mt-12 text-sm tracking-wide text-charcoal/50 uppercase">
      Trusted by tech & home brands
    </p>
  </div>
</section>
