---
import { services } from '../data/services';
---

<section id="services" class="bg-offwhite px-6 py-24 sm:py-32 lg:px-12">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold tracking-wide text-clay uppercase">Services</p>
      <h2
        class="mt-4 font-[family-name:var(--font-display)] text-4xl leading-tight font-medium text-ink sm:text-5xl"
      >
        What I can create for your brand
      </h2>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service) => (
          <div class="rounded-2xl bg-cream p-8 shadow-sm">
            <h3 class="font-[family-name:var(--font-display)] text-xl font-medium text-ink">
              {service.title}
            </h3>
            <p class="mt-3 text-base leading-relaxed text-charcoal/75">{service.description}</p>

            <ul class="mt-6 space-y-2 border-t border-stone pt-6">
              {service.features.map((feature) => (
                <li class="flex items-start gap-2 text-sm text-charcoal/70">
                  <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-clay" />
                  {feature}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-14 text-center">
      <p class="text-base text-charcoal/70">
        Don't see what you need? <a href="#contact" class="font-medium text-clay-dark underline-offset-4 hover:underline">Let's talk about it.</a>
      </p>
    </div>
  </div>
</section>
