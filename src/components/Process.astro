---
import { processSteps } from '../data/process';
---

<section id="process" class="bg-offwhite px-6 py-24 sm:py-32 lg:px-12">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold tracking-wide text-clay uppercase">Process</p>
      <h2
        class="mt-4 font-[family-name:var(--font-display)] text-4xl leading-tight font-medium text-ink sm:text-5xl"
      >
        How we'll work together
      </h2>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
      {
        processSteps.map((step) => (
          <div>
            <p class="font-[family-name:var(--font-display)] text-5xl font-medium text-clay-light">
              {step.number}
            </p>
            <h3 class="mt-4 font-[family-name:var(--font-display)] text-xl font-medium text-ink">
              {step.title}
            </h3>
            <p class="mt-3 text-base leading-relaxed text-charcoal/75">{step.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
