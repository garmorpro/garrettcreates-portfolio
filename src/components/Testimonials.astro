---
import { testimonials } from '../data/testimonials';
---

<section class="px-6 py-24 sm:py-32 lg:px-12">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold tracking-wide text-clay uppercase">Testimonials</p>
      <h2
        class="mt-4 font-[family-name:var(--font-display)] text-4xl leading-tight font-medium text-ink sm:text-5xl"
      >
        What brands say
      </h2>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        testimonials.map((testimonial) => (
          <div class="flex flex-col rounded-2xl bg-offwhite p-8 shadow-sm">
            <svg viewBox="0 0 24 24" class="h-8 w-8 fill-clay-light">
              <path d="M7 11c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm0 2c-2.21 0-4 1.79-4 4v3h8v-3c0-2.21-1.79-4-4-4zm10-2c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm0 2c-2.21 0-4 1.79-4 4v3h8v-3c0-2.21-1.79-4-4-4z" />
            </svg>
            <p class="mt-5 flex-1 text-base leading-relaxed text-charcoal/85">
              "{testimonial.quote}"
            </p>
            <div class="mt-6 border-t border-stone pt-5">
              <p class="text-sm font-medium text-ink">{testimonial.name}</p>
              <p class="text-sm text-charcoal/60">{testimonial.role}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
