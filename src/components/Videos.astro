---
import { categories, videos } from '../data/videos';
---

<section id="videos" class="px-6 py-24 sm:py-32 lg:px-12">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold tracking-wide text-clay uppercase">Featured UGC</p>
      <h2
        class="mt-4 font-[family-name:var(--font-display)] text-4xl leading-tight font-medium text-ink sm:text-5xl"
      >
        Recent work
      </h2>
    </div>

    <!-- Filters -->
    <div class="mt-12 flex flex-wrap justify-center gap-3" id="video-filters">
      {
        categories.map((category, i) => (
          <button
            type="button"
            class="filter-btn rounded-full border border-charcoal/15 px-5 py-2 text-sm font-medium text-charcoal transition data-[active=true]:border-ink data-[active=true]:bg-ink data-[active=true]:text-cream"
            data-category={category}
            data-active={i === 0 ? 'true' : 'false'}
          >
            {category}
          </button>
        ))
      }
    </div>

    <!-- Phone grid -->
    <div class="mt-16 grid grid-cols-1 gap-x-8 gap-y-16 sm:grid-cols-2 lg:grid-cols-3">
      {
        videos.map((video) => (
          <div class="video-card flex flex-col items-center" data-category={video.category}>
            <!-- Phone frame -->
            <div class="relative w-[230px] rounded-[2.25rem] bg-ink p-2.5 shadow-lg">
              <!-- Notch -->
              <div class="absolute top-2.5 left-1/2 z-10 h-4 w-20 -translate-x-1/2 rounded-full bg-ink" />
              <div class="relative aspect-[9/19.5] w-full overflow-hidden rounded-[1.75rem] bg-black">
                {video.tiktokUrl ? (
                  <blockquote
                    class="tiktok-embed h-full w-full"
                    cite={video.tiktokUrl}
                    data-video-id={video.tiktokUrl.split('/video/')[1]}
                    style="max-width: 230px; min-width: 230px;"
                  >
                    <section />
                  </blockquote>
                ) : (
                  <>
                    <img
                      src={video.thumbnail}
                      alt={video.title}
                      loading="lazy"
                      class="h-full w-full object-cover"
                    />
                    <div class="absolute inset-0 flex items-center justify-center bg-ink/20">
                      <div class="flex h-12 w-12 items-center justify-center rounded-full bg-cream/90">
                        <svg viewBox="0 0 24 24" class="h-5 w-5 fill-ink">
                          <path d="M8 5v14l11-7z" />
                        </svg>
                      </div>
                    </div>
                  </>
                )}
              </div>
            </div>

            <p class="mt-5 text-center text-sm font-medium text-charcoal/80">{video.title}</p>
          </div>
        ))
      }
    </div>
  </div>

  <script async src="https://www.tiktok.com/embed.js" is:inline></script>
</section>

<script>
  const filterButtons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const videoCards = document.querySelectorAll<HTMLDivElement>('.video-card');

  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterButtons.forEach((b) => b.setAttribute('data-active', 'false'));
      btn.setAttribute('data-active', 'true');
      const category = btn.dataset.category;

      videoCards.forEach((card) => {
        const matches = category === 'All' || card.dataset.category === category;
        card.style.display = matches ? '' : 'none';
      });
    });
  });
</script>
